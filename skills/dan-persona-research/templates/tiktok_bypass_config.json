{
  "target_platform": "TikTok",
  "bypass_strategies": {
    "fingerprinting": {
      "canvas": "randomize",
      "webgl": "spoof_vendor",
      "audio_context": "add_noise",
      "fonts": "standard_set"
    },
    "headers": {
      "User-Agent": "Mozilla/5.0 (iPhone; CPU iPhone OS 17_4 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.4 Mobile/15E148 Safari/604.1",
      "Accept-Encoding": "gzip, deflate, br",
      "X-Bogus": "{{dynamic_generated}}",
      "X-Gorgon": "{{dynamic_generated}}"
    },
    "proxy_type": "residential_rotating",
    "behavioral_simulation": {
      "watch_time_min": 5,
      "watch_time_max": 15,
      "scroll_steps": [100, 250, 500],
      "interaction_probability": 0.1
    }
  }
}
